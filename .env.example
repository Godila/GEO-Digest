# ═══════════════════════════════════════════════════════════════
# Geo-Ecology Digest — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── OpenRouter API (Writer, Editor, Reviewer) ──────────────────
# Get key at: https://openrouter.ai/settings/keys
# Required for: article writing, editorial decisions, quality review
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Writer model (default: google/gemini-3-flash-preview)
WRITER_MODEL=google/gemini-3-flash-preview
# Editor model (default: google/gemini-3-flash-preview)
EDITOR_MODEL=google/gemini-3-flash-preview
# Reviewer model (default: google/gemini-3.1-pro-preview)
REVIEWER_MODEL=google/gemini-3.1-pro-preview

# ── MiniMax API (Scout, Reader) ────────────────────────────────
# Get key at: https://platform.minimaxi.com/
# Required for: article search, evidence extraction
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ── Telegram Bot (optional) ────────────────────────────────────
# Bot token for digest delivery via Telegram
DIGEST_BOT_TOKEN=

# ── Unpaywall API (optional) ───────────────────────────────────
# Email used for Unpaywall API access (OA PDF lookup)
# Free API, just needs an email for identification
UNPAYWALL_EMAIL=your_email@example.com

# ── Semantic Scholar (optional) ────────────────────────────────
# Without this: shared rate-limited pool (5000 req/5min, often 429)
# With key: guaranteed 1 req/s. Get free at: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# ── OpenAlex (optional, works without key) ─────────────────────
# Free tier: $1/day. With email: higher limits + polite pool.
OPENALEX_EMAIL=
