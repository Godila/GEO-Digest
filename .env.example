# Geo-Ecology Digest — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Telegram Bot ─────────────────────────────────────
# Create via @BotFather: https://t.me/BotFather
DIGEST_BOT_TOKEN=your_telegram_bot_token_here

# ── MiniMax LLM ──────────────────────────────────────
# Used for: article enrichment (RU summaries), graph semantic edges
# Get key at: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ── Semantic Scholar (optional) ──────────────────────
# Without this: shared rate-limited pool (5000 req/5min, often 429)
# With key: guaranteed 1 req/s. Get free at: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# ── OpenAlex (optional, works without key) ───────────
# Free tier: $1/day. With key: higher limits.
# Get at: https://docs.openalex.org/
OPENALEX_EMAIL=
